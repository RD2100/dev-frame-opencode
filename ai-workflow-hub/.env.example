# ============================================================
# ai-workflow-hub 环境变量
# 复制为 .env 并填入真实值
# ============================================================

# --- Codex / GPT-5.5 (规划、复审、裁决) ---
CODEX_API_KEY=
CODEX_API_BASE=https://api.openai.com/v1
CODEX_MODEL_PLANNER=gpt-5.5-codex
CODEX_MODEL_REVIEWER=gpt-5.5-codex
CODEX_MODEL_FINALIZER=gpt-5.5-codex

# --- OpenCode / DSV4 Pro (编码执行、修复) ---
OPENCODE_API_KEY=
OPENCODE_API_BASE=https://api.deepseek.com/v1
OPENCODE_MODEL_EXECUTOR=deepseek-v4-pro
OPENCODE_MODEL_FIXER=deepseek-v4-pro

# --- OpenRouter (可选，用于统一路由) ---
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- 超时与并发 ---
SHELL_TIMEOUT_SECONDS=600
AIHUB_LOG_LEVEL=INFO
