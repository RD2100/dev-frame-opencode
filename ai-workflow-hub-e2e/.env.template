# TestFrame 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.template .env

# ===== Android =====
ANDROID_HOME=/path/to/android-sdk

# ===== 微信开发者工具 =====
WECHAT_DEVTOOL_PATH=/path/to/wechat-devtools/cli

# ===== MeterSphere =====
MS_API_KEY=your-api-key
MS_ACCESS_KEY=your-access-key

# ===== WeTest 云真机 =====
WETEST_API_KEY=your-api-key
WETEST_API_SECRET=your-api-secret

# ===== Sentry =====
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=your-auth-token

# ===== Bugly =====
BUGLY_ANDROID_APP_ID=your-app-id
BUGLY_ANDROID_APP_KEY=your-app-key
BUGLY_MINIAPP_APP_ID=your-miniapp-app-id

# ===== 测试账号 =====
TEST_USER_PASSWORD=test_password
TEST_USER_TOKEN=test_token
