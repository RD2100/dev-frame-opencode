{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubmitConfig",
  "description": "Configuration schema for CDP submit targets",
  "type": "object",
  "properties": {
    "conversations": {
      "type": "object",
      "properties": {
        "active": {"type": "string", "description": "Active GPT conversation ID"},
        "fallback": {"type": "string", "description": "Fallback conversation ID"}
      }
    },
    "cdp": {
      "type": "object",
      "properties": {
        "host": {"type": "string", "default": "localhost"},
        "port": {"type": "integer", "default": 9222}
      }
    },
    "selectors": {
      "type": "object",
      "properties": {
        "file_input": {"type": "string"},
        "editor": {"type": "string"},
        "send_button": {"type": "string"}
      }
    },
    "timing": {
      "type": "object",
      "properties": {
        "poll_wait_seconds": {"type": "integer", "default": 60},
        "max_poll_attempts": {"type": "integer", "default": 3}
      }
    }
  }
}
